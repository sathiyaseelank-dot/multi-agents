def cmd_search(args: argparse.Namespace) -> int:
    """Search across sessions using ripgrep."""
    query = args.query
    
    # Check if rg is available
    try:
        subprocess.run(["rg", "--version"], capture_output=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(colored("Error: ripgrep (rg) not found. Install with: sudo apt install ripgrep", Colors.FAIL))
        return 1
    
    # Search in memory, logs, output
    search_dirs = []
    if args.memory and get_memory_dir().exists():
        search_dirs.append(str(get_memory_dir()))
    if args.logs and get_logs_dir().exists():
        search_dirs.append(str(get_logs_dir()))
    if args.output and get_output_dir().exists():
        search_dirs.append(str(get_output_dir()))
    
    if not search_dirs:
        search_dirs = [str(get_memory_dir())]
    
    cmd = ["rg", "--color", "always", "--line-number", "--context", "2"]
    
    if args.json_only:
        cmd.extend(["--type", "json"])
    
    cmd.extend([query] + search_dirs)
    
    result = subprocess.run(cmd)
    return result.returncode


# ─────────────────────────────────────────────────────────────────────────────
# Main CLI
# ─────────────────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        prog="multi-cli",
        description="Multi-Agent Orchestrator - Enhanced CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  multi run "Build a REST API"
  multi run "Build a login system" --self-heal
  multi resume
  multi list --status completed
  multi status 20260329-101850
  multi agents
  multi search "authentication" --memory
  multi quick plan "Build a todo app"
  multi clean --days 7
  multi info
        """,
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")
    
    # run command
    run_parser = subparsers.add_parser("run", help="Run a new orchestration task")
    run_parser.add_argument("task", nargs="?", help="Task description")
    run_parser.add_argument("--file", "-f", help="Read task from file")
    run_parser.add_argument("--verbose", "-v", action="store_true")
    run_parser.add_argument("--dry-run", action="store_true")
    run_parser.add_argument("--plan-only", action="store_true")
    run_parser.add_argument("--self-heal", action="store_true")
    run_parser.add_argument("--max-repairs", type=int, default=5)
    run_parser.add_argument("--orchestration-heal", action="store_true")
    run_parser.add_argument("--health-timeout", type=float, default=60.0)
    run_parser.add_argument("--max-orch-heals", type=int, default=3)
    run_parser.add_argument("--json", action="store_true")
    run_parser.set_defaults(func=cmd_run)
    
    # resume command
    resume_parser = subparsers.add_parser("resume", help="Resume an interrupted session")
    resume_parser.add_argument("session_id", nargs="?", help="Session ID to resume")
    resume_parser.set_defaults(func=cmd_resume)
    
    # list command
    list_parser = subparsers.add_parser("list", help="List previous sessions")
    list_parser.add_argument("--status", choices=["completed", "incomplete"], help="Filter by status")
    list_parser.add_argument("--limit", "-n", type=int, help="Limit results")
    list_parser.set_defaults(func=cmd_list)
    
    # status command
    status_parser = subparsers.add_parser("status", help="Show detailed session status")
    status_parser.add_argument("session_id", help="Session ID")
    status_parser.set_defaults(func=cmd_status)
    
    # clean command
    clean_parser = subparsers.add_parser("clean", help="Clean up old sessions")
    clean_parser.add_argument("--all", action="store_true", help="Clean everything")
    clean_parser.add_argument("--days", "-d", type=int, default=30, help="Remove files older than N days")
    clean_parser.set_defaults(func=cmd_clean)
    
    # agents command
    agents_parser = subparsers.add_parser("agents", help="Check agent availability")
    agents_parser.set_defaults(func=cmd_agents)
    
    # quick command
    quick_parser = subparsers.add_parser("quick", help="Quick run with presets")
    quick_parser.add_argument("preset", choices=["plan", "test", "heal", "full"], help="Preset to use")
    quick_parser.add_argument("task", help="Task description")
    quick_parser.set_defaults(func=cmd_quick)
    
    # info command
    info_parser = subparsers.add_parser("info", help="Show project information")
    info_parser.set_defaults(func=cmd_info)
    
    # search command
    search_parser = subparsers.add_parser("search", help="Search across sessions")
    search_parser.add_argument("query", help="Search query")
    search_parser.add_argument("--memory", action="store_true", help="Search in memory/")
    search_parser.add_argument("--logs", action="store_true", help="Search in logs/")
    search_parser.add_argument("--output", action="store_true", help="Search in output/")
    search_parser.add_argument("--json-only", action="store_true", help="Search only JSON files")
    search_parser.set_defaults(func=cmd_search)
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 0
    
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
