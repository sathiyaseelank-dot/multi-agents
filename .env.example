# Multi-Agent Orchestrator Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Agent Model Configuration
# =============================================================================

# Backend Agent (OpenCode) - Model selection
# Recommended: claude/claude-3.5-sonnet for high-capacity tasks
# Default: qwen/qwen3-32b (may have rate limits)
OPENCODE_MODEL=claude/claude-3.5-sonnet

# Frontend Agent (Gemini) - Model selection
# Recommended: gemini-2.0-flash for UI generation
GEMINI_MODEL=gemini-2.0-flash

# Testing Agent (Kilo) - Model selection
# Recommended: claude/claude-3.5-sonnet for test generation
KILO_MODEL=claude/claude-3.5-sonnet

# =============================================================================
# API Keys (if required by your agent setup)
# =============================================================================

# Note: Most agents use stored credentials (~/.codex, ~/.gemini, etc.)
# Add any additional API keys here if needed

# Example:
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# Orchestrator Configuration
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Default timeout for agent execution (seconds)
DEFAULT_TIMEOUT=120

# Default retry count for failed agent calls
DEFAULT_RETRY_COUNT=3

# =============================================================================
# Flask API Configuration (if using the API component)
# =============================================================================

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# Database configuration
DATABASE_URL=sqlite:///flask_api/users.db

# =============================================================================
# Optional: Web Search Configuration
# =============================================================================

# Enable web search for agents (if supported)
# ENABLE_WEB_SEARCH=false
